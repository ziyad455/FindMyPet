rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin
    // Robust check to avoid crashes when document doesn't exist
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }
    
    // Users collection rules
    match /users/{userId} {
      // Users can read their own document
      // Also allow admins to read any user document
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Users can create their own document on registration
      allow create: if isAuthenticated() && isOwner(userId);
      
      // Users can update their own non-role profile fields
      // Admins can update any field including roles
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
      );
      
      // No one can delete user documents
      allow delete: if false;
    }
    
    // Pets collection rules
    match /pets/{petId} {
      // Anyone can read approved pets (for QR code pages)
      allow read: if resource != null && resource.data.get('status', 'pending') == 'approved';
      
      // Authenticated users can read their own pets
      allow read: if isAuthenticated() && resource != null && resource.data.get('userId', '') == request.auth.uid;
      
      // Admins can read all pets
      allow read: if isAdmin();
      
      // Authenticated users can create pets (with their own userId)
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
      
      // Users can update their own pending pets (except status)
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.userId == request.auth.uid;
      
      // Admins can update any pet (including status changes)
      allow update: if isAdmin();
      
      // Users can delete their own pending pets
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        resource.data.status == 'pending';
      
      // Admins can delete any pet
      allow delete: if isAdmin();
    }
  }
}
